# Environment variables for hw-chat project
# Copy this file to .env and fill in your actual values

# LLM API Keys
ZHIPU_API_KEY=your_zhipu_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Search Engine API Key
SERPER_API_KEY=your_serper_api_key_here

# Zilliz Vector Database Token
ZILLIZ_TOKEN=your_zilliz_token_here

# Model Paths (local paths to model weights)
# LOCAL_MODEL_PATH=/path/to/your/local/model
# EMBED_MODEL_PATH=/path/to/your/embedding/model
# RERANKER_MODEL_PATH=/path/to/your/reranker/model
